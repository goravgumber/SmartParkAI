{
  "name": "smartpark-server",
  "version": "1.0.0",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon src/index.js",
    "start": "node src/index.js",
    "start:render": "sh -c 'npx prisma db push && (node prisma/seed.js || echo \"Seed step failed/skipped; continuing startup\") && node src/index.js'",
    "db:migrate": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:seed": "node prisma/seed.js",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.54.0",
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "mqtt": "^5.5.0",
    "pg": "^8.16.3",
    "socket.io": "^4.7.4",
    "twilio": "^5.5.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.0",
    "prisma": "^7.4.2"
  }
}
